# OpenAI-compatible API for strategy generation and advice.
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=90000

# Pharos Atlantic testnet.
PHAROS_RPC_URL=https://atlantic.dplabs-internal.com
PHAROS_CHAIN_ID=688689

# Optional for wallet readiness checks. Never commit a real private key.
PRIVATE_KEY=0xreplace_with_private_key

# MCP HTTP server.
PORT=3001

# Optional x402 paid gateway scaffolding. Disabled by default for Phase 1 review.
X402_ENABLED=false
X402_NETWORK=pharos-atlantic-testnet
X402_CHAIN_ID=688689
X402_RECEIVER_ADDRESS=0xreplace_with_receiver_address
X402_FACILITATOR_URL=https://replace-with-x402-facilitator.example
X402_DEFAULT_ASSET=PHRS
X402_DEFAULT_AMOUNT=0.01
X402_REQUIRE_CONFIRMATION=true
X402_DEV_ACCEPT_UNSIGNED_RECEIPT=false
